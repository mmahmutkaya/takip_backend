// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────

enum ProjectRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum CasePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NotificationType {
  CASE_ASSIGNED
  CASE_UPDATED
  CASE_CLOSED
  CASE_COMMENT
  MEMBER_ADDED
  MEMBER_REMOVED
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

// ─── User ──────────────────────────────────────────────

model User {
  id                String           @id @default(cuid())
  email             String           @unique
  name              String
  passwordHash      String
  avatarUrl         String?
  isActive          Boolean          @default(true)
  isEmailVerified   Boolean          @default(false)
  plan              SubscriptionPlan @default(FREE)
  planExpiresAt     DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  refreshTokens      RefreshToken[]
  emailVerifications EmailVerification[]
  projectMembers     ProjectMember[]
  casesCreated       Case[]          @relation("CaseCreatedBy")
  caseUpdates        CaseUpdate[]
  notifications      Notification[]
  meetingsCreated    Meeting[]

  @@map("users")
}

model EmailVerification {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("email_verifications")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─── Project ───────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  slug        String   @unique
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  ProjectMember[]
  cases    Case[]
  meetings Meeting[]

  @@map("projects")
}

model ProjectMember {
  id          String      @id @default(cuid())
  projectId   String
  userId      String
  role        ProjectRole @default(MEMBER)
  title       String?     // Ozel unvan: "Proje Muduru", "Yazilim Gelistirici" vb.
  permissions String[]    @default([]) // Ornek: ["CREATE_CASE", "DELETE_CASE"]
  joinedAt    DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  casesAssigned Case[] @relation("CaseAssignee")

  @@unique([projectId, userId])
  @@map("project_members")
}

// ─── Case ──────────────────────────────────────────────

model Case {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      CaseStatus   @default(OPEN)
  priority    CasePriority @default(MEDIUM)
  dueDate     DateTime?
  closedAt    DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("CaseCreatedBy", fields: [createdById], references: [id])

  assigneeId String?
  assignee   ProjectMember? @relation("CaseAssignee", fields: [assigneeId], references: [id])

  updates       CaseUpdate[]
  meetingLinks  MeetingCase[]
  notifications Notification[]

  @@map("cases")
}

model CaseUpdate {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  caseId   String
  case     Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@map("case_updates")
}

// ─── Meeting (opsiyonel) ───────────────────────────────

model Meeting {
  id          String   @id @default(cuid())
  title       String
  description String?
  scheduledAt DateTime
  location    String? // fiziksel konum veya link
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User    @relation(fields: [createdById], references: [id])

  cases MeetingCase[]

  @@map("meetings")
}

model MeetingCase {
  meetingId String
  caseId    String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  case    Case    @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@id([meetingId, caseId])
  @@map("meeting_cases")
}

// ─── Notification ──────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  message   String
  isRead    Boolean          @default(false)
  payload   Json? // ek veri (caseId, projectId vb.)
  createdAt DateTime         @default(now())

  recipientId String
  recipient   User   @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  caseId String?
  case   Case?  @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@map("notifications")
}
